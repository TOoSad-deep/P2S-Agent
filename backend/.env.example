# P2S-Agent Environment Configuration
# Copy this file to .env and fill in your values

# LLM Configuration (for LLM candidate generation and refinement)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_SUPPORTS_IMAGE=false

# Proxy (optional, for accessing overseas APIs)
# PROXY=http://127.0.0.1:7890
# PROXY=socks5://127.0.0.1:7890

# Service Configuration
HOST=0.0.0.0
PORT=8001
FRONTEND_URL=http://localhost:5174

# Screenshot Configuration
SCREENSHOT_WIDTH=512
SCREENSHOT_HEIGHT=512
RENDER_TIMEOUT_MS=2000

# LangSmith Tracing (optional, disabled by default)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=p2s-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TAGS=p2s-agent
