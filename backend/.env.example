# P2S-Agent Environment Configuration
# Copy this file to .env and fill in your values

# LLM Configuration (fallback default model for candidate generation/refinement)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_SUPPORTS_IMAGE=false

# Preset models (frontend-selectable via the model picker). Up to 3 slots.
# Leave *_API_KEY blank to keep a preset as a placeholder ("not configured");
# it shows disabled in the UI until a key is supplied. Keys here are NEVER
# returned by GET /api/models — only id/label/model/supports_image/configured.
MODEL_1_ID=claude-opus
MODEL_1_LABEL=Claude Opus
MODEL_1_API_KEY=your_api_key_here
MODEL_1_BASE_URL=https://aihubmix.com/v1
MODEL_1_MODEL=claude-opus-4-8
MODEL_1_SUPPORTS_IMAGE=true

MODEL_2_ID=mimo-v2.5
MODEL_2_LABEL=MiMo v2.5
MODEL_2_API_KEY=
MODEL_2_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MODEL_2_MODEL=mimo-v2.5
MODEL_2_SUPPORTS_IMAGE=true

MODEL_3_ID=qwen-3.7-plus
MODEL_3_LABEL=Qwen 3.7 Plus
MODEL_3_API_KEY=
MODEL_3_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_3_MODEL=qwen-3.7-plus
MODEL_3_SUPPORTS_IMAGE=true

# Proxy (optional, for accessing overseas APIs)
# PROXY=http://127.0.0.1:7890
# PROXY=socks5://127.0.0.1:7890

# Service Configuration
HOST=0.0.0.0
PORT=8001
FRONTEND_URL=http://localhost:5174

# Screenshot Configuration
SCREENSHOT_WIDTH=512
SCREENSHOT_HEIGHT=512
RENDER_TIMEOUT_MS=2000

# LangSmith Tracing (optional, disabled by default)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=p2s-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TAGS=p2s-agent
